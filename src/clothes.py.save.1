@router.get("/clothes/{clothes_id}")
def get_clothes_detail(clothes_id: int):

    db: Session = SessionLocal()

    try:

        query_sql = """
        SELECT
            c.id,
            c.name,
            c.category,
            c.color,
            c.season,
            c.style,
            c.brand,
            c.created_at,
            i.image_url
        FROM clothes c
        LEFT JOIN images i
        ON c.id = i.clothes_id
        WHERE c.id = :clothes_id
        """

        result = db.execute(
            text(query_sql),
            {"clothes_id": clothes_id}
        )

        row = result.fetchone()

        if not row:

            return {

                "status": "error",

                "message": "clothes not found"

            }

        # ========= 转换URL =========

        if row.image_url:

            image_name = os.path.basename(row.image_url)

            image_url = (
                f"http://16.171.9.129:8000/image/"
                f"{image_name}"
            )

        else:

            image_url = None

        return {

            "status": "success",

            "data": {

                "id": row.id,

                "name": row.name,

                "category": row.category,

                "color": row.color,

                "season": row.season,

                "style": row.style,

                "brand": row.brand,

                "image_url": image_url,

                "created_at": str(row.created_at)

            }

        }

    except Exception as e:

        return {

            "status": "error",

            "message": str(e)

        }

    finally:

        db.close()


# ==========================================
# 删除衣服
# ==========================================

@router.delete("/clothes/{clothes_id}")
def delete_clothes(clothes_id: int):

    db: Session = SessionLocal()

    try:

        query_sql = """
        SELECT image_url
        FROM images
        WHERE clothes_id = :clothes_id
        """

        result = db.execute(
            text(query_sql),
            {"clothes_id": clothes_id}
        )

        image_rows = result.fetchall()

        for row in image_rows:

            image_path = row.image_url

            if os.path.exists(image_path):

                os.remove(image_path)

        db.execute(
            text("""
            DELETE FROM images
            WHERE clothes_id = :clothes_id
            """),
            {"clothes_id": clothes_id}
        )

        db.execute(
            text("""
            DELETE FROM clothes
            WHERE id = :clothes_id
            """),
            {"clothes_id": clothes_id}
        )

        db.commit()

        return {

            "status": "success",

            "message": f"clothes {clothes_id} deleted"

        }

    except Exception as e:

        db.rollback()

        return {

            "status": "error",

            "message": str(e)

        }

    finally:

        db.close()


