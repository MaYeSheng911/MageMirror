from fastapi import APIRouter, UploadFile, File
from sqlalchemy.orm import Session
from sqlalchemy import text
from config.database import SessionLocal

from ai.vision import analyze_clothes
from ai.image_processor import process_image

import os
import uuid
from datetime import datetime

router = APIRouter()

UPLOAD_DIR = "/home/ubuntu/MageMirror/uploads"

os.makedirs(UPLOAD_DIR, exist_ok=True)


# ==========================================
# 上传衣服（含抠图 + 强制PNG）
# ==========================================

@router.post("/upload-clothes")
async def upload_clothes(file: UploadFile = File(...)):

    db: Session = SessionLocal()

    try:

        # ========= 生成唯一PNG文件 =========

        file_id = str(uuid.uuid4())

        file_name = f"{file_id}.png"

        file_path = os.path.join(
            UPLOAD_DIR,
            file_name
        )

        # ========= 保存上传文件 =========

        with open(file_path, "wb") as f:

            content = await file.read()

            f.write(content)

        # ========= 抠图 =========

        processed_path = process_image(file_path)

        # 强制使用 PNG 文件名
        image_name = os.path.basename(processed_path)

        # ========= 插入 clothes =========

        insert_clothes_sql = """
        INSERT INTO clothes (
            user_id,
            name,
            category,
            color,
            season,
            style,
            brand,
            created_at
        )
        VALUES (
            1,
            :name,
            'unknown',
            'unknown',
            'unknown',
            'unknown',
            'unknown',
            :created_at
        )
        RETURNING id
        """

        result = db.execute(
            text(insert_clothes_sql),
            {
                "name": image_name,
                "created_at": datetime.now()
            }
        )

        clothes_id = result.fetchone()[0]

        # ========= 插入 images =========

        insert_image_sql = """
        INSERT INTO images (
            clothes_id,
            image_url,
            is_primary,
            created_at
        )
        VALUES (
            :clothes_id,
            :image_url,
            true,
            :created_at
        )
        """

        db.execute(
            text(insert_image_sql),
            {
                "clothes_id": clothes_id,
                "image_url": processed_path,
                "created_at": datetime.now()
            }
        )

        db.commit()

        # ========= AI识别 =========

        ai_result = analyze_clothes(processed_path)

        category = ai_result.get("category", "unknown")
        color = ai_result.get("color", "unknown")
        season = ai_result.get("season", "unknown")
        style = ai_result.get("style", "unknown")
        brand = ai_result.get("brand", "unknown")

        # ========= 更新 clothes =========

        update_sql = """
        UPDATE clothes
        SET
            category = :category,
            color = :color,
            season = :season,
            style = :style,
            brand = :brand
        WHERE id = :clothes_id
        """

        db.execute(
            text(update_sql),
            {
                "category": category,
                "color": color,
                "season": season,
                "style": style,
                "brand": brand,
                "clothes_id": clothes_id
            }
        )

        db.commit()

        return {

            "status": "success",

            "clothes_id": clothes_id,

            "ai_result": ai_result

        }

    except Exception as e:

        db.rollback()

        print("ERROR:", e)

        return {

            "status": "error",

            "message": str(e)

        }

    finally:

        db.close()


